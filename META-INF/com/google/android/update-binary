#!/sbin/sh

# Flashable installer for the Kitsunping Magisk module.
# - Prepares a temporary workspace via Magisk utilities.
# - Extracts module files and runs customize.sh (or setup.sh fallback) to stage assets.
# - Copies service scripts, applies permissions, and cleans build-only files.
# - Leaves a concise install log under /data/adb/logs.

# --- Constants and defaults ---
UMASK=022
PERSISTDIR="/sbin/.magisk/mirror/persist"
NVBASE="/data/adb"
LOGDIR="$NVBASE/logs"

umask "$UMASK"

# --- Small helpers ---
ui_print() { echo "$@"; }
log_line() { [ -n "$LOGFILE" ] && echo "$1" | tee -a "$LOGFILE" || echo "$1"; }

copy_boot_script() {
  local name="$1"
  local src_installer="$TMPDIR/installer/$name"
  local dest="$MODPATH/$name"

  if [ ! -f "$src_installer" ]; then
    log_line " [x] Archivo faltante: $name (installer)"
    exit 1
  fi

  cp -af "$src_installer" "$dest" || { log_line " [x] Error al copiar $name"; exit 1; }
  chmod 0755 "$dest" 2>/dev/null || true
  log_line " [✓] Copiado: [$src_installer] --> [$dest]"
}

preserve_existing_backups() {
  PREV_BACKUP_STASH="$TMPDIR/.prev_backups"
  PREV_BACKUP_FOUND=0

  if [ -d "$MODPATH/configs" ]; then
    mkdir -p "$PREV_BACKUP_STASH" 2>/dev/null || true
    # Preserve base and rotated snapshots from previous install.
    for bf in "$MODPATH/configs"/kitsuneping_original_backup*.conf; do
      [ -f "$bf" ] || continue
      cp -af "$bf" "$PREV_BACKUP_STASH/" 2>/dev/null && PREV_BACKUP_FOUND=1
    done
  fi

  if [ "$PREV_BACKUP_FOUND" = "1" ]; then
    log_line " [i] Previous backups preserved before update"
  fi
}

restore_preserved_backups() {
  [ "${PREV_BACKUP_FOUND:-0}" = "1" ] || return 0
  [ -d "$PREV_BACKUP_STASH" ] || return 0

  mkdir -p "$MODPATH/configs" 2>/dev/null || true
  for bf in "$PREV_BACKUP_STASH"/kitsuneping_original_backup*.conf; do
    [ -f "$bf" ] || continue
    cp -af "$bf" "$MODPATH/configs/" 2>/dev/null || true
  done
  log_line " [i] Previous backups restored into new installation"
}

# --- Setup environment ---
OUTFD="$2"
ZIPFILE="$3"

mount /data 2>/dev/null
. "/data/adb/magisk/util_functions.sh"
setup_flashable
mount_partitions
api_level_arch_detect

if [ "$BOOTMODE" ]; then
  boot_actions
else
  recovery_actions
fi

# --- Preparation ---
trap 'rm -rf "$TMPDIR"' EXIT
unzip -o "$ZIPFILE" -d "$TMPDIR" >&2 || { echo " [x] ZIP file extraction failed"; exit 1; }

if [ "$BOOTMODE" ]; then
  MODDIRNAME="modules_update"
else
  MODDIRNAME="modules"
fi

MODID=$(grep_prop "id" "$TMPDIR/module.prop")
MODNAME=$(grep_prop "name" "$TMPDIR/module.prop")
MODVERS=$(grep_prop "version" "$TMPDIR/module.prop")
MODULEROOT="$NVBASE/$MODDIRNAME"
MODPATH="$MODULEROOT/$MODID"
NEWMODPATH="$MODULEROOT/$MODID"
LOGFILE="$LOGDIR/${MODID}_up_binary.log"

mkdir -p "$LOGDIR"

if [ -z "$MODID" ] || [ -z "$MODNAME" ] || [ -z "$MODVERS" ]; then
  log_line " [x] Error: Missing module information (ID, Name, Version)."
  exit 1
fi

# Clean up previous installation
if [ -d "$MODPATH" ]; then
  preserve_existing_backups
  log_line " [i] Previous installation detected, removing old module files..."
  rm -rf "$MODPATH" || { log_line " [SYS] [up-bi] Failed to remove old module files"; exit 1; }
fi

# Create module directory
if ! mkdir -p "$MODPATH" 2>/dev/null; then
  log_line " [x] Failed to create directory $MODPATH"
  exit 1
fi

# --- Installation ---
if unzip -o "$ZIPFILE" -d "$MODPATH" >&2; then
  log_line " [i] Files extracted successfully"
else
  log_line " [x] ZIP file extraction failed"
  exit 1
fi

restore_preserved_backups

INSTALL_SCRIPT=""
if [ -f "$MODPATH/customize.sh" ]; then
  INSTALL_SCRIPT="$MODPATH/customize.sh"
elif [ -f "$MODPATH/setup.sh" ]; then
  INSTALL_SCRIPT="$MODPATH/setup.sh"
fi

# Ejecutar script de instalación (prefer customize.sh, fallback setup.sh)
if [ -n "$INSTALL_SCRIPT" ]; then
  log_line " [i] install script found: $INSTALL_SCRIPT"
  chmod +x "$INSTALL_SCRIPT" || { log_line " [x] Failed to set executable permissions on install script"; exit 1; }
  set_perm "$INSTALL_SCRIPT" 0 0 0755 u:object_r:system_file:s0
  set_perm "$MODPATH/addon/Net_Calibrate/calibrate.sh" 0 0 0755 u:object_r:system_file:s0
  . "$INSTALL_SCRIPT"
else
  log_line " [x] install script not found (expected customize.sh or setup.sh), canceling installation"
  exit 1
fi

copy_boot_script "service.sh"
copy_boot_script "uninstall.sh"
copy_boot_script "post-fs-data.sh"

# Re-apply module-specific permissions AFTER copying root boot scripts.
# Important: Magisk's default set_permissions may chmod bundled binaries (ping/ip/jq/bc) to 0644,
# breaking runtime detection (e.g., daemon says "ping binary not found").
if [ -f "$MODPATH/addon/functions/utils/Kitsutils.sh" ]; then
  # shellcheck disable=SC1090
  . "$MODPATH/addon/functions/utils/Kitsutils.sh"
  if command -v set_permissions_module >/dev/null 2>&1; then
    set_permissions_module "$MODPATH" "$LOGFILE"
    log_line " [i] Module permissions applied (set_permissions_module)"
  else
    log_line " [!] WARN: set_permissions_module not available after sourcing Kitsutils.sh"
  fi
else
  log_line " [!] WARN: Kitsutils.sh not found; cannot apply module-specific permissions"
fi

[ "$DEBUG" = "true" ] && set -x
[ "$SKIPMOUNT" = "true" ] && touch "$MODPATH/skip_mount"

for TARGET in $REPLACE; do
  log_line "[*] Replacing destination: $TARGET"
  mktouch "$MODPATH$TARGET/.replace"
done

if [ "$BOOTMODE" = "true" ]; then
  mktouch "$NVBASE/modules/$MODID/update"
  cp -af "$MODPATH/module.prop" "$NVBASE/modules/$MODID/module.prop"
fi

if [ -f "$MODPATH/sepolicy.rule" ]; then
  copy_sepolicy_rules
fi

# Clean build-only assets but keep addon/functions/{debug,utils}
rm -rf "$MODPATH/scripts"
rm -rf "$MODPATH/META-INF"
rm -rf "$MODPATH/setup.sh"
rm -rf "$MODPATH/customize.sh"
rm -rf "$MODPATH/CHANGELOG.md"


log_line " [i] Installation/update process completed"
log_line " [i] You can now restart the device"

cd /
[ "$BOOTMODE" != "true" ] && recovery_cleanup

exit 0